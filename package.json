{
  "name": "zoogent",
  "version": "0.4.10",
  "description": "Lightweight AI agent orchestrator with Skill Graph, Memory, Consensus, and MCP",
  "license": "MIT",
  "mcpName": "io.github.bepunk/zoogent",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/client/index.js"
  },
  "bin": {
    "zoogent": "./dist/cli.js"
  },
  "files": [
    "dist",
    "drizzle",
    "client"
  ],
  "scripts": {
    "build": "tsc && cp -r src/public dist/public",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node dist/index.js",
    "mcp": "node dist/mcp.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx --env-file=.env src/db/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "prepublishOnly": "npm run build",
    "postinstall": "node -e \"console.log('\\n  ZooGent installed. To get started:\\n\\n    mkdir my-agents && cd my-agents\\n    zoogent init\\n    zoogent start\\n    claude mcp add zoogent -s project -- npx zoogent mcp\\n    claude\\n\\n  Then type: help me build an agent team\\n')\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/generative-ai": "^0.24.0",
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.7.9",
    "better-auth": "^1.5.5",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.0.0",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.5.2",
    "date-fns": "^4.1.0",
    "discord.js": "^14.26.3",
    "drizzle-orm": "^0.45.1",
    "esbuild": "^0.24.2",
    "fast-xml-parser": "^4.5.1",
    "googleapis": "^144.0.0",
    "he": "^1.2.0",
    "hono": "^4.12.8",
    "imapflow": "^1.0.182",
    "jimp": "^1.6.1",
    "jsonwebtoken": "^9.0.2",
    "lodash-es": "^4.17.21",
    "mailparser": "^3.7.2",
    "marked": "^15.0.6",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "nodemailer": "^7.0.10",
    "openai": "^6.0.0",
    "p-limit": "^6.2.0",
    "p-map": "^7.0.3",
    "p-queue": "^8.0.1",
    "p-retry": "^6.2.1",
    "slugify": "^1.6.6",
    "tiktoken": "^1.0.18",
    "tsx": "^4.21.0",
    "turndown": "^7.2.0",
    "ws": "^8.20.0",
    "yaml": "^2.6.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
